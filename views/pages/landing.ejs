    <script>
    // Fallback function in case main script doesn't load
    function toggleTool() {
        let toolSection = document.getElementById("tool");
        let heroBtn = document.getElementById("heroCtaBtn");
        
        if (toolSection.style.display === "none") {
            toolSection.style.display = "block";
            if (heroBtn) heroBtn.innerText = "Close";
            // Scroll to tool
            toolSection.scrollIntoView({ behavior: 'smooth', block: 'center' });
        } else {
            toolSection.style.display = "none";
            if (heroBtn) heroBtn.innerText = "Check Your Financial Score";
        }
    }
    </script>