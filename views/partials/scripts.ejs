/* ═══════════════════════
   ANALYZE SCORE
═══════════════════════ */
function analyze() {
    let income   = parseFloat(document.getElementById('income').value);
    let expenses = parseFloat(document.getElementById('expenses').value);
    let savings  = parseFloat(document.getElementById('savings').value);
    let emi      = parseFloat(document.getElementById('emi').value);

    if (!income || !expenses || isNaN(savings) || isNaN(emi)) {
        alert("Please fill all fields to calculate your score.");
        return;
    }

    document.getElementById('loader').style.display = 'block';
    document.getElementById('result').style.display = 'none';

    setTimeout(() => {
        let score = Math.round(
            (savings / expenses) * 20 +
            (income - expenses) / income * 40 +
            (1 - emi / income) * 40
        );

        let statusText, statusClass;
        if      (score >= 75) { statusText = "Safe";     statusClass = "safe"; }
        else if (score >= 50) { statusText = "Moderate"; statusClass = "moderate"; }
        else                  { statusText = "Risky";    statusClass = "risky"; }

        document.getElementById('loader').style.display = 'none';
        document.getElementById('result').style.display = 'block';
        document.getElementById('scoreNum').innerText   = score;

        let badge = document.getElementById('statusBadge');
        badge.innerText = statusText;
        badge.className = "status " + statusClass;

        document.getElementById('insight1').innerText =
            "Your financial profile shows " + statusText.toLowerCase() + " stability.";
        document.getElementById('insight2').innerText =
            "Investment decisions may improve long-term outcomes but increase short-term risk.";
        document.getElementById('scenarioA').innerText =
            "Growth potential increases but volatility rises.";
        document.getElementById('scenarioB').innerText =
            "Stability remains but long-term growth slows.";

        // Sync to dashboard
        document.getElementById('dash-score').innerText       = score;
        document.getElementById('dash-score-label').innerText = statusText + " Stability";

        setTimeout(() => {
            document.getElementById('popup').style.display = 'flex';
        }, 1200);
    }, 1200);
}

/* ═══════════════════════
   AI CHAT
   ✅ Ab /api/chat call hoga — Vercel Serverless Function
   localhost:3000 ki zaroorat nahi!
═══════════════════════ */
/* ═══════════════════════
   UNIFIED AI CHAT LOGIC
═══════════════════════ */
async function sendUnifiedMessage(type) {
    let inputId = type === 'dashboard' ? 'dashboardUserInput' : 'user-input';
    let chatBoxId = type === 'dashboard' ? 'dashboardChatBox' : 'chat-messages';
    
    let input = document.getElementById(inputId).value.trim();
    if (!input) return;

    let chatBox = document.getElementById(chatBoxId);

    // User message
    let userMsg = document.createElement('div');
    userMsg.className = type === 'dashboard' ? 'chat-msg user' : 'message user-message';
    userMsg.innerText = input;
    chatBox.appendChild(userMsg);
    document.getElementById(inputId).value = '';
    chatBox.scrollTop = chatBox.scrollHeight;

    // Typing indicator
    let typing = document.createElement('div');
    typing.className = type === 'dashboard' ? 'chat-msg bot' : 'message ai-message';
    typing.style.fontStyle = 'italic';
    typing.style.opacity = '0.7';
    typing.innerHTML = 'FINCOTIX is analyzing...';
    chatBox.appendChild(typing);
    chatBox.scrollTop = chatBox.scrollHeight;

    try {
        const response = await fetch("/api/chat", {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify({ message: input })
        });

        const data = await response.json();
        chatBox.removeChild(typing);

        let botMsg = document.createElement('div');
        botMsg.className = type === 'dashboard' ? 'chat-msg bot' : 'message ai-message';
        botMsg.innerText = data.reply || "I'm sorry, I couldn't process that. Please try again.";
        chatBox.appendChild(botMsg);

    } catch (err) {
        if (chatBox.contains(typing)) chatBox.removeChild(typing);
        let errMsg = document.createElement('div');
        errMsg.className = type === 'dashboard' ? 'chat-msg bot' : 'message ai-message';
        errMsg.style.color = '#ef4444';
        errMsg.innerText = "⚠️ Connection lost. Please check your network or API settings.";
        chatBox.appendChild(errMsg);
    }

    chatBox.scrollTop = chatBox.scrollHeight;
    if (window.lucide) lucide.createIcons();
}

