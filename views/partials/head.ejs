<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>FINCOTIX AI</title>
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script src="https://unpkg.com/lucide@latest"></script>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;700&display=swap" rel="stylesheet">
<style>
* { box-sizing: border-box; }

body {
    margin: 0;
    font-family: 'Inter', sans-serif;
    background: radial-gradient(circle at top, #0f172a, #020617);
    color: white;
    overflow-x: hidden;
}

/* ══════════════════════════════
   PAGE SWITCHING
══════════════════════════════ */
.page { display: none; }
.page.active { display: block; }
#dashboard-page { display: none; }
#dashboard-page.active { display: flex; min-height: 100vh; }

/* ══════════════════════════════
   LANDING — NAVBAR
══════════════════════════════ */
.navbar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 10px 40px;
    background: rgba(15, 23, 42, 0.9);
    backdrop-filter: blur(10px);
    position: sticky;
    top: 0;
    z-index: 100;
}
.logo img { max-height: 120px; height: auto; width: auto; display: block; }
.nav-menu { display: flex; align-items: center; }
.nav-btn {
    padding: 10px 22px;
    border-radius: 8px;
    border: none;
    font-weight: 600;
    font-size: 14px;
    background: linear-gradient(90deg, #3b82f6, #6366f1);
    color: white;
    cursor: pointer;
    transition: 0.3s;
    width: auto;
}
.nav-btn:hover { transform: scale(1.05); box-shadow: 0 0 16px rgba(99,102,241,0.5); }

/* ══════════════════════════════
   LANDING — HERO
══════════════════════════════ */
.hero {
    text-align: center;
    padding: 100px 20px 60px;
    animation: fadeIn 1.2s ease-in;
}
h1 {
    font-size: 52px;
    background: linear-gradient(90deg, #38bdf8, #6366f1);
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
    margin-bottom: 20px;
    line-height: 1.2;
}
.subtitle {
    color: #cbd5f5;
    max-width: 700px;
    margin: auto;
    font-size: 18px;
    line-height: 1.6;
}
.cta {
    display: inline-block;
    margin-top: 30px;
    padding: 14px 32px;
    border-radius: 10px;
    border: none;
    font-size: 16px;
    font-weight: 600;
    background: linear-gradient(90deg, #3b82f6, #6366f1);
    color: white;
    cursor: pointer;
    transition: 0.3s;
    width: auto;
}
.cta:hover { transform: scale(1.05); box-shadow: 0 0 20px rgba(99,102,241,0.6); }

/* ══════════════════════════════
   LANDING — SECTIONS
══════════════════════════════ */
.section {
    max-width: 1000px;
    margin: auto;
    padding: 60px 20px;
    animation: fadeInUp 1s ease;
}
.section h2 {
    font-size: 28px;
    margin-bottom: 16px;
    background: linear-gradient(90deg, #38bdf8, #6366f1);
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
    display: inline-block;
}
.section p, .section li { color: #cbd5f5; line-height: 1.7; font-size: 15px; }
.section ul, .section ol { padding-left: 20px; }
.section li { margin-bottom: 8px; }
.divider { border: none; border-top: 1px solid rgba(255,255,255,0.07); margin: 0 20px; }

/* ══════════════════════════════
   FEATURE CARDS
══════════════════════════════ */
.features {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 20px;
    margin-top: 20px;
}
.feature-card {
    background: rgba(255,255,255,0.05);
    backdrop-filter: blur(10px);
    padding: 24px;
    border-radius: 14px;
    border: 1px solid rgba(255,255,255,0.1);
    transition: 0.3s;
    text-align: center;
    font-size: 15px;
    color: #e2e8f0;
}
.feature-card:hover { transform: translateY(-6px); background: rgba(255,255,255,0.08); }

/* ══════════════════════════════
   TOOL FORM
══════════════════════════════ */
.glass-card {
    background: rgba(255,255,255,0.05);
    backdrop-filter: blur(10px);
    padding: 30px;
    border-radius: 14px;
    border: 1px solid rgba(255,255,255,0.1);
    margin-top: 20px;
    max-width: 420px;
}
input[type="number"], input[type="email"], input[type="text"] {
    width: 100%;
    padding: 14px;
    margin: 8px 0;
    border-radius: 10px;
    border: 1px solid rgba(255,255,255,0.1);
    background: rgba(15, 23, 42, 0.6);
    color: white;
    font-size: 14px;
    font-family: 'Inter', sans-serif;
}
button {
    padding: 14px;
    border-radius: 10px;
    border: none;
    font-size: 15px;
    font-weight: 600;
    background: linear-gradient(90deg, #3b82f6, #6366f1);
    color: white;
    cursor: pointer;
    width: 100%;
    transition: 0.3s;
    margin-top: 6px;
    font-family: 'Inter', sans-serif;
}
button:hover { transform: scale(1.03); box-shadow: 0 0 20px rgba(99,102,241,0.6); }

/* ══════════════════════════════
   LOADER & RESULT
══════════════════════════════ */
.loader {
    display: none;
    margin: 20px auto;
    border: 4px solid #1e293b;
    border-top: 4px solid #38bdf8;
    border-radius: 50%;
    width: 45px;
    height: 45px;
    animation: spin 1s linear infinite;
}
@keyframes spin { 100% { transform: rotate(360deg); } }

.result-box {
    margin-top: 24px;
    padding: 20px;
    border-radius: 14px;
    background: rgba(255,255,255,0.04);
    animation: fadeInUp 1s ease;
}
.score-num { font-size: 60px; font-weight: bold; line-height: 1; }
.status {
    font-size: 17px; font-weight: 600; padding: 6px 14px;
    border-radius: 8px; display: inline-block; margin: 10px 0;
}
.safe     { background: #16a34a; }
.moderate { background: #eab308; color: black; }
.risky    { background: #dc2626; }
.scenario {
    margin-top: 16px; padding: 18px; border-radius: 12px;
    background: rgba(255,255,255,0.04); transition: 0.3s; text-align: left;
}
.scenario:hover { transform: translateY(-4px); }
.scenario p { color: #cbd5f5; font-size: 14px; }

/* ══════════════════════════════
   POPUP
══════════════════════════════ */
.popup {
    position: fixed; top: 0; left: 0;
    width: 100%; height: 100%;
    background: rgba(0,0,0,0.85);
    display: none; justify-content: center; align-items: center; z-index: 1000;
}
.popup-content {
    background: #0f172a; padding: 30px; border-radius: 14px;
    text-align: center; border: 1px solid rgba(255,255,255,0.1);
    animation: fadeIn 0.5s ease; max-width: 360px; width: 90%;
}

/* ══════════════════════════════
   FOOTER
══════════════════════════════ */
.footer { text-align: center; padding: 40px; color: #94a3b8; font-size: 12px; line-height: 1.6; }

/* ══════════════════════════════
   DASHBOARD — SIDEBAR
══════════════════════════════ */
.sidebar {
    width: 240px; min-height: 100vh; background: #0f172a;
    padding: 24px 20px; flex-shrink: 0; display: flex;
    flex-direction: column; border-right: 1px solid rgba(255,255,255,0.07);
}
.sidebar-logo {
    font-size: 22px; font-weight: 700;
    background: linear-gradient(90deg, #38bdf8, #6366f1);
    -webkit-background-clip: text; background-clip: text; -webkit-text-fill-color: transparent;
    transition: all 0.3s ease;
    margin-bottom: 32px;
}
.sidebar-logo:hover {
    transform: scale(1.05);
    filter: brightness(1.2);
}
.sidebar ul { list-style: none; padding: 0; margin: 0; flex: 1; }
.sidebar li {
    padding: 12px 14px; cursor: pointer; color: #94a3b8;
    border-radius: 8px; margin-bottom: 4px; font-size: 14px;
    font-weight: 500; transition: 0.2s;
}
.sidebar li:hover, .sidebar li.active-nav { background: rgba(56,189,248,0.08); color: #38bdf8; }
.sidebar-back {
    margin-top: auto; padding: 10px 14px; border-radius: 8px;
    border: 1px solid rgba(255,255,255,0.1); background: transparent;
    color: #94a3b8; font-size: 13px; cursor: pointer; width: 100%;
    text-align: left; transition: 0.2s;
}
.sidebar-back:hover { background: rgba(255,255,255,0.05); color: white; transform: none; box-shadow: none; }

/* ══════════════════════════════
   DASHBOARD — MAIN
══════════════════════════════ */
.dash-main { flex: 1; padding: 30px; background: #020617; overflow-y: auto; }
.dash-header {
    display: flex; justify-content: space-between;
    align-items: center; margin-bottom: 28px;
}
.dash-header h2 { font-size: 24px; margin: 0; color: #e2e8f0; }
.upgrade-btn {
    padding: 10px 20px; border: none; border-radius: 8px;
    font-size: 13px; font-weight: 600;
    background: linear-gradient(90deg, #3b82f6, #6366f1);
    color: white; cursor: pointer; width: auto; transition: 0.3s;
}
.upgrade-btn:hover { transform: scale(1.05); box-shadow: 0 0 14px rgba(99,102,241,0.5); }

/* ── Dashboard Tab Sections ── */
.dash-section { display: none; }
.dash-section.active { display: block; }

/* ── Stat Cards ── */
.dash-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 18px; margin-bottom: 24px;
}
.dash-card {
    background: rgba(255,255,255,0.05); backdrop-filter: blur(10px);
    padding: 22px; border-radius: 14px; border: 1px solid rgba(255,255,255,0.08); transition: 0.3s;
}
.dash-card:hover { transform: translateY(-4px); background: rgba(255,255,255,0.07); }
.dash-card h3 { margin: 0 0 12px; font-size: 12px; color: #94a3b8; text-transform: uppercase; letter-spacing: 0.05em; }
.dash-card .big-score { font-size: 48px; font-weight: 700; color: #38bdf8; line-height: 1; }
.dash-card .score-label { font-size: 13px; color: #64748b; margin-top: 6px; }

/* ── Bar Tracks ── */
.bar-track { height: 10px; background: #1e293b; border-radius: 10px; margin-top: 12px; overflow: hidden; }
.bar-fill { height: 100%; border-radius: 10px; background: linear-gradient(90deg, #38bdf8, #6366f1); transition: width 1s ease; }
.bar-label { display: flex; justify-content: space-between; font-size: 12px; color: #64748b; margin-top: 6px; }

/* ── Chart Containers ── */
.chart-card {
    background: rgba(255,255,255,0.04);
    border: 1px solid rgba(255,255,255,0.07);
    padding: 24px; border-radius: 14px; margin-bottom: 20px;
}
.chart-card h4 { margin: 0 0 16px; font-size: 12px; color: #94a3b8; text-transform: uppercase; letter-spacing: 0.05em; }
.chart-row { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; margin-bottom: 20px; }

/* ── Vault ── */
.vault-item {
    display: flex; align-items: center; gap: 10px;
    padding: 12px 0; border-bottom: 1px solid rgba(255,255,255,0.05);
    font-size: 14px; color: #cbd5f5;
}
.vault-item:last-child { border-bottom: none; }
.vault-dot { width: 8px; height: 8px; border-radius: 50%; background: #22c55e; flex-shrink: 0; }

/* ── AI Chat ── */
.chat-box {
    height: 400px; overflow-y: auto; 
    background: rgba(10, 22, 40, 0.4);
    padding: 20px; border-radius: 16px;
    border: 1px solid rgba(255,255,255,0.06);
    display: flex; flex-direction: column; gap: 14px;
    backdrop-filter: blur(12px);
    box-shadow: inset 0 0 40px rgba(0,0,0,0.2);
    scrollbar-width: thin;
    scrollbar-color: rgba(255,255,255,0.1) transparent;
}
.chat-box::-webkit-scrollbar { width: 5px; }
.chat-box::-webkit-scrollbar-thumb { background: rgba(255,255,255,0.1); border-radius: 10px; }

.chat-msg {
    padding: 12px 18px; border-radius: 18px;
    font-size: 14px; line-height: 1.6; max-width: 85%;
    position: relative; transition: 0.3s;
    animation: slideInUp 0.3s ease-out;
}
@keyframes slideInUp {
    from { opacity: 0; transform: translateY(10px); }
    to { opacity: 1; transform: translateY(0); }
}

.chat-msg.user { 
    background: linear-gradient(135deg, #3b82f6, #6366f1); 
    align-self: flex-end; color: white; 
    border-bottom-right-radius: 4px;
    box-shadow: 0 4px 15px rgba(59, 130, 246, 0.3);
}
.chat-msg.bot { 
    background: rgba(255,255,255,0.05); 
    align-self: flex-start; color: #cbd5f5; 
    border: 1px solid rgba(255,255,255,0.08);
    border-bottom-left-radius: 4px;
    backdrop-filter: blur(4px);
}

.chat-input-row { 
    display: flex; gap: 12px; margin-top: 16px; 
    background: rgba(255,255,255,0.03);
    padding: 8px; border-radius: 14px;
    border: 1px solid rgba(255,255,255,0.06);
}
.chat-input-row input { 
    flex: 1; margin: 0; border: none; background: transparent; 
    padding: 12px 16px; font-size: 14px; color: white; outline: none;
}
.chat-input-row button { 
    width: auto; padding: 0 20px; margin: 0; 
    height: 44px; display: flex; align-items: center; justify-content: center;
    border-radius: 10px;
}

/* ══════════════════════════════
   ANIMATIONS
══════════════════════════════ */
@keyframes fadeIn { from { opacity: 0; } to { opacity: 1; } }
@keyframes fadeInUp {
    from { opacity: 0; transform: translateY(30px); }
    to   { opacity: 1; transform: translateY(0); }
}

/* ══════════════════════════════
   RESPONSIVE DESIGN OVERRIDES
══════════════════════════════ */
.hamburger { display: none; background: none; border: none; color: white; cursor: pointer; padding: 5px; }

/* Tablet Breakpoint */
@media (max-width: 1024px) {
    h1 { font-size: 44px; }
    .section h2 { font-size: 24px; }
    .features { grid-template-columns: repeat(2, 1fr); gap: 15px; }
    .dash-grid { grid-template-columns: repeat(2, 1fr); }
    .hero, .section { padding-left: 30px; padding-right: 30px; }
}

/* Mobile Breakpoint */
@media (max-width: 768px) {
    .navbar { padding: 15px 20px; flex-wrap: wrap; }
    .hamburger { display: block; margin-left: auto; }
    .nav-menu { display: none; width: 200px; flex-direction: column; gap: 10px; position: absolute; top: 100%; right: 20px; background: rgba(15, 23, 42, 0.95); padding: 15px; border-radius: 12px; border: 1px solid rgba(255,255,255,0.1); box-shadow: 0 10px 25px rgba(0,0,0,0.5); }
    .nav-menu.active { display: flex; animation: fadeInUp 0.3s ease forwards; }
    .nav-btn { width: 100%; text-align: center; }
    
    h1 { font-size: 32px; line-height: 1.3; }
    .subtitle { font-size: 16px; }
    .hero { padding: 50px 15px 30px; }
    .section { padding: 30px 15px; }
    
    .features, .dash-grid, .chart-row { grid-template-columns: 1fr; gap: 15px; }
    
    .glass-card { width: 100%; padding: 20px; box-sizing: border-box; }
    .chart-card { padding: 15px; overflow-x: auto; }
    
    .sidebar { position: fixed; left: -260px; top: 0; z-index: 1000; height: 100vh; overflow-y: auto; transition: left 0.3s ease; box-shadow: 5px 0 15px rgba(0,0,0,0.5); }
    .sidebar.active { left: 0; }
    .sidebar-overlay { display: none; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.5); z-index: 999; }
    .sidebar-overlay.active { display: block; }
    
    .dash-main { padding: 15px; }
    .dash-header { flex-direction: column; align-items: flex-start; gap: 15px; }
    .dash-header h2 { font-size: 20px; }
    .dash-card .big-score { font-size: 36px; }
    
    .chat-modal { width: 90% !important; right: 5% !important; bottom: 80px !important; height: 70vh !important; max-height: 500px; }
    .ai-assistant-btn { bottom: 15px; right: 15px; width: 55px; height: 55px; }
}
</style>
</head>